    "target": "0856123456789",
    "price": "58507",
    "sn": null,
    "status": "pending",
    "created_at": "2025-03-01 10:30:00"
  },
  "code": 202
}</code></pre>
                                    </div>
                                </div>

                                <div class="bg-gray-50 rounded-lg border border-gray-200 p-4">
                                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Parameter</h3>
                                    <div class="overflow-x-auto">
                                        <table class="min-w-full text-sm">
                                            <thead class="bg-gray-100 text-gray-700">
                                                <tr>
                                                    <th class="px-4 py-2 text-left font-medium">Nama</th>
                                                    <th class="px-4 py-2 text-left font-medium">Tipe</th>
                                                    <th class="px-4 py-2 text-left font-medium">Deskripsi</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-200">
                                                <tr>
                                                    <td class="px-4 py-2 font-mono">api_key</td>
                                                    <td class="px-4 py-2">string</td>
                                                    <td class="px-4 py-2">API Key anda</td>
                                                </tr>
                                                <tr>
                                                    <td class="px-4 py-2 font-mono">code</td>
                                                    <td class="px-4 py-2">string</td>
                                                    <td class="px-4 py-2">Kode layanan (KODE1, KODE2, dll)</td>
                                                </tr>
                                                <tr>
                                                    <td class="px-4 py-2 font-mono">reff_id</td>
                                                    <td class="px-4 py-2">string</td>
                                                    <td class="px-4 py-2">ID referensi unik</td>
                                                </tr>
                                                <tr>
                                                    <td class="px-4 py-2 font-mono">target</td>
                                                    <td class="px-4 py-2">string</td>
                                                    <td class="px-4 py-2">Nomor tujuan</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Check Transaksi Status -->
                    <section id="transaksi-status" class="scroll-mt-20">
                        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex flex-wrap items-center gap-3">
